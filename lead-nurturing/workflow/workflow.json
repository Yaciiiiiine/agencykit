        300
      ],
      "parameters": {
        "fromEmail": "={{ $json.from_email }}",
        "toEmail": "={{ $json.lead_email }}",
        "subject": "=Bienvenue {{ $json.lead_name }}",
        "emailType": "html",
        "message": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Bienvenue</title>\n  <style>\n    body { margin: 0; padding: 0; background-color: #f5f5f0; font-family: 'Georgia', serif; color: #2c2c2c; }\n    .wrapper { max-width: 600px; margin: 40px auto; background: #ffffff; border-radius: 4px; overflow: hidden; }\n    .header { background-color: #1a1a2e; padding: 40px 48px; }\n    .header h1 { margin: 0; color: #ffffff; font-size: 22px; font-weight: 400; letter-spacing: 2px; text-transform: uppercase; }\n    .header p { margin: 6px 0 0; color: #a0a0b8; font-size: 13px; letter-spacing: 1px; }\n    .body { padding: 48px; }\n    .body h2 { font-size: 20px; font-weight: 400; color: #1a1a2e; margin: 0 0 24px; }\n    .body p { font-size: 15px; line-height: 1.8; margin: 0 0 18px; color: #444; }\n    .highlight { background: #f5f5f0; border-left: 3px solid #1a1a2e; padding: 16px 20px; margin: 28px 0; font-size: 14px; color: #555; }\n    .cta { display: inline-block; margin-top: 12px; background-color: #1a1a2e; color: #ffffff; text-decoration: none; padding: 14px 32px; font-size: 14px; letter-spacing: 1px; border-radius: 2px; }\n    .footer { border-top: 1px solid #eee; padding: 28px 48px; font-size: 12px; color: #999; line-height: 1.7; }\n    .footer a { color: #999; text-decoration: underline; }\n  </style>\n</head>\n<body>\n  <div class=\"wrapper\">\n    <div class=\"header\">\n      <h1>{{agency_name}}</h1>\n      <p>Agence Immobilière</p>\n    </div>\n    <div class=\"body\">\n      <h2>Bonjour {{lead_name}},</h2>\n      <p>\n        Nous avons bien reçu votre demande et nous vous remercions de votre confiance.\n        Notre équipe est à votre disposition pour vous accompagner dans votre projet immobilier\n        avec soin et professionnalisme.\n      </p>\n      <p>\n        Que vous souhaitiez acquérir, vendre ou investir, nous mettons notre connaissance\n        approfondie du marché local au service de vos ambitions.\n      </p>\n      <div class=\"highlight\">\n        Un conseiller dédié prendra contact avec vous dans les 24 heures pour échanger\n        sur votre projet et répondre à toutes vos questions.\n      </div>\n      <p>En attendant, n'hésitez pas à consulter nos dernières sélections de biens.</p>\n      <a href=\"{{agency_website}}\" class=\"cta\">Voir nos biens</a>\n    </div>\n    <div class=\"footer\">\n      <p>\n        {{agency_name}} · {{agency_address}}<br />\n        <a href=\"mailto:{{agency_email}}\">{{agency_email}}</a> · {{agency_phone}}\n      </p>\n      <p>Vous recevez cet email car vous avez effectué une demande sur notre site.<br />\n        <a href=\"{{unsubscribe_url}}\">Se désabonner</a>\n      </p>\n    </div>\n  </div>\n</body>\n</html>\n",
        "options": {}
      },
      "credentials": {
        "smtp": {
          "id": "",
          "name": "SMTP"
        }
