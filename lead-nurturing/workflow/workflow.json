        "subject": "Suivi personnalisé",
        "emailType": "html",
        "message": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Votre projet — Suivi personnalisé</title>\n  <style>\n    body { margin: 0; padding: 0; background-color: #f5f5f0; font-family: 'Georgia', serif; color: #2c2c2c; }\n    .wrapper { max-width: 600px; margin: 40px auto; background: #ffffff; border-radius: 4px; overflow: hidden; }\n    .header { background-color: #1a1a2e; padding: 40px 48px; }\n    .header h1 { margin: 0; color: #ffffff; font-size: 22px; font-weight: 400; letter-spacing: 2px; text-transform: uppercase; }\n    .header p { margin: 6px 0 0; color: #a0a0b8; font-size: 13px; letter-spacing: 1px; }\n    .body { padding: 48px; }\n    .body h2 { font-size: 20px; font-weight: 400; color: #1a1a2e; margin: 0 0 24px; }\n    .body p { font-size: 15px; line-height: 1.8; margin: 0 0 18px; color: #444; }\n    .property-card { border: 1px solid #e8e8e4; border-radius: 4px; padding: 24px; margin: 28px 0; }\n    .property-card h3 { margin: 0 0 8px; font-size: 16px; color: #1a1a2e; font-weight: 400; }\n    .property-card p { margin: 0; font-size: 14px; color: #777; }\n    .property-card .price { margin-top: 12px; font-size: 18px; color: #1a1a2e; font-weight: 400; }\n    .cta { display: inline-block; margin-top: 12px; background-color: #1a1a2e; color: #ffffff; text-decoration: none; padding: 14px 32px; font-size: 14px; letter-spacing: 1px; border-radius: 2px; }\n    .cta-secondary { display: inline-block; margin-top: 12px; margin-left: 16px; color: #1a1a2e; text-decoration: underline; font-size: 14px; }\n    .footer { border-top: 1px solid #eee; padding: 28px 48px; font-size: 12px; color: #999; line-height: 1.7; }\n    .footer a { color: #999; text-decoration: underline; }\n  </style>\n</head>\n<body>\n  <div class=\"wrapper\">\n    <div class=\"header\">\n      <h1>{{agency_name}}</h1>\n      <p>Agence Immobilière</p>\n    </div>\n    <div class=\"body\">\n      <h2>{{lead_name}}, voici notre sélection pour vous</h2>\n      <p>\n        Deux jours se sont écoulés depuis votre demande, et nous avons pris le temps\n        d'analyser votre profil pour vous proposer des biens qui correspondent\n        précisément à vos critères.\n      </p>\n      <p>\n        Voici une première sélection que notre équipe a constituée spécialement pour vous :\n      </p>\n\n      <div class=\"property-card\">\n        <h3>{{property_1_title}}</h3>\n        <p>{{property_1_description}}</p>\n        <p class=\"price\">{{property_1_price}}</p>\n      </div>\n\n      <div class=\"property-card\">\n        <h3>{{property_2_title}}</h3>\n        <p>{{property_2_description}}</p>\n        <p class=\"price\">{{property_2_price}}</p>\n      </div>\n\n      <p>\n        Ces biens vous correspondent ? Réservons un créneau pour en discuter\n        et, si vous le souhaitez, organiser une visite rapidement.\n      </p>\n\n      <a href=\"{{booking_url}}\" class=\"cta\">Prendre rendez-vous</a>\n      <a href=\"{{listings_url}}\" class=\"cta-secondary\">Voir tous nos biens</a>\n    </div>\n    <div class=\"footer\">\n      <p>\n        {{agency_name}} · {{agency_address}}<br />\n        <a href=\"mailto:{{agency_email}}\">{{agency_email}}</a> · {{agency_phone}}\n      </p>\n      <p><a href=\"{{unsubscribe_url}}\">Se désabonner</a></p>\n    </div>\n  </div>\n</body>\n</html>\n",
        "options": {}
